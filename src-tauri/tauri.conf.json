{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui-tauri/main/src-tauri/gen/schemas/desktop-schema.json",
  "productName": "lii",
  "version": "0.1.0",
  "identifier": "com.lii.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "lii - Translation Assistant",
        "width": 800,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/iamkhaliliii/lii/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUzOTA4QkYxM0I0Q0UxQzMKUldURDRVdzc4WXVRNDhSbCtLNmpNTXNnQUV4VGQyK2RNRFVKTmcyQkkzZnZweU9zL3ZUb1JtNG8K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
